# Copy to .env locally. Never commit .env or real credentials.
# Add providers consecutively, starting at 1.
AI_PROVIDER_1_NAME=apihost
AI_PROVIDER_1_BASE_URL=https://apihost.cn/v1
AI_PROVIDER_1_API_KEY=your_api_key_here
AI_PROVIDER_1_MODELS=gpt-5.4-mini,gpt-5.4,gpt-4.1-mini

AI_PROVIDER_2_NAME=openrouter
AI_PROVIDER_2_BASE_URL=https://openrouter.ai/api/v1
AI_PROVIDER_2_API_KEY=your_api_key_here
AI_PROVIDER_2_MODELS=openai/gpt-4.1-mini,anthropic/claude-sonnet-4

AI_TIMEOUT_SECONDS=60
AI_COOLDOWN_SECONDS=300
AI_MAX_RETRIES=1

# Legacy fallback (used only when AI_PROVIDER_1_BASE_URL is absent):
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1-mini
